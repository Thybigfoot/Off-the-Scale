    - target: {fileID: 8410169369649938629, guid: f63230ab1983b6948bd4ddf124878b15, type: 3}
      propertyPath: lines.Array.data[0].text
      value: Welcome, to Salarium! And your name is...
      objectReference: {fileID: 0}
    - target: {fileID: 8410169369649938629, guid: f63230ab1983b6948bd4ddf124878b15, type: 3}
      propertyPath: lines.Array.data[1].text
      value: Angelus...
      objectReference: {fileID: 0}
    - target: {fileID: 8410169369649938629, guid: f63230ab1983b6948bd4ddf124878b15, type: 3}
      propertyPath: lines.Array.data[2].text
      value: Well I, mercury, will be your humble guide
      objectReference: {fileID: 0}
    - target: {fileID: 8410169369649938629, guid: f63230ab1983b6948bd4ddf124878b15, type: 3}
      propertyPath: lines.Array.data[3].text
