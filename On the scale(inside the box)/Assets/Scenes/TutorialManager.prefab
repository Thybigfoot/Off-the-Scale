  panelMercury: {fileID: 0}
  panelAngelus: {fileID: 0}
  dialogueText: {fileID: 0}
  delayBeforeShow: 1
  lines:
  - isMercury: 1
    text: Welcome, to Salarium! And your name is...
  - isMercury: 0
    text: Angelus...
  - isMercury: 1
    text: Well I, mercury, will be your humble guide
  - isMercury: 1
    text: through the trade route!
  - isMercury: 1
    text: You can use the arrow keys (or AD!) to move)
  - isMercury: 1
    text: Use either space or c to jump...
  - isMercury: 1
    text: And hold your mouse to shake salt!
  - isMercury: 1
    text: You can use the salt to move the scales
  - isMercury: 1
    text: Grab the key and get to the door!
